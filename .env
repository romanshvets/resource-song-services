# RESOURCE-DB PROPS
RESOURCE_DB_NAME=resource-db
RESOURCE_DB_PORT=5432
RESOURCE_DB_USER=postgres
RESOURCE_DB_PASSWORD=postgres

# SONG-DB PROPS
SONG_DB_NAME=song-db
SONG_DB_PORT=5433
SONG_DB_USER=postgres
SONG_DB_PASSWORD=postgres

# RESOURCE-SERVICE PROPS
RESOURCE_SERVICE_DATASOURCE_URL="jdbc:postgresql://resource-db:${RESOURCE_DB_PORT}/${RESOURCE_DB_NAME}"

# SONG-SERVICE PROPS
SONG_SERVICE_PORT=8085
SONG_SERVICE_URL="http://song-service:${SONG_SERVICE_PORT}/songs"
SONG_SERVICE_DATASOURCE_URL="jdbc:postgresql://song-db:${SONG_DB_PORT}/${SONG_DB_NAME}"